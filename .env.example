# Valentine v3 Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit the actual .env file — it contains secrets!

# ============================================================
# CORE LLM PROVIDERS (at least one required)
# ============================================================
GROQ_API_KEY=gsk_...                    # https://console.groq.com/keys
CEREBRAS_API_KEY=csk-...                # https://cloud.cerebras.ai/
SAMBANOVA_API_KEY=...                   # https://cloud.sambanova.ai/

# ============================================================
# TELEGRAM (required)
# ============================================================
TELEGRAM_BOT_TOKEN=...                  # From @BotFather
ADMIN_USER_ID=...                       # Your Telegram user ID (for admin commands)

# ============================================================
# GITHUB (required for code operations)
# ============================================================
GITHUB_PAT=ghp_...                      # Personal Access Token
                                        # Scopes needed: repo, workflow, read:org
GITHUB_REPOS=Tee-David/valentine        # Comma-separated repo whitelist
                                        # SAFETY: Only these repos can be accessed!
                                        # Example: Tee-David/valentine,Tee-David/portfolio

# ============================================================
# VERCEL (optional — enables deployment via MCP)
# ============================================================
VERCEL_TOKEN=...                        # From https://vercel.com/account/tokens
                                        # The agent can deploy, manage domains,
                                        # env vars, and rollback deployments.
                                        # It will ONLY operate on projects you
                                        # explicitly mention in conversation.

# ============================================================
# RENDER (optional — enables service management via MCP)
# ============================================================
RENDER_API_KEY=rnd_...                  # From https://dashboard.render.com/settings#api-keys
                                        # The agent can create services, trigger
                                        # deploys, and manage env vars.
                                        # It will ONLY operate on services you
                                        # explicitly mention in conversation.

# ============================================================
# SEARCH (optional — enables web search)
# ============================================================
SEARXNG_URL=                            # Self-hosted SearXNG instance URL
BRAVE_API=                              # Brave Search API key (fallback)

# ============================================================
# INFRASTRUCTURE (auto-configured on the VM)
# ============================================================
REDIS_URL=redis://localhost:6379/0      # Session storage, job queue, pubsub
QDRANT_HOST=localhost                   # Vector DB for Mem0 memory
QDRANT_PORT=6333
WORKSPACE_DIR=/opt/valentine/workspace  # Where projects are created
TIMEZONE=Africa/Lagos                   # Your timezone

# ============================================================
# SAFETY NOTES
# ============================================================
# 1. GITHUB_REPOS whitelist prevents the agent from accessing repos
#    you didn't explicitly allow. Always set this!
# 2. Vercel/Render operations are scoped by conversation — the agent
#    will only touch projects you mention in the current context.
# 3. The ADMIN_USER_ID ensures only you can run admin commands.
# 4. All file operations are confined to WORKSPACE_DIR.
# 5. Secrets are NEVER echoed back in Telegram messages.
